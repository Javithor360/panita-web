// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Photo {
  id          String    @id @default(uuid())
  url         String
  title       String?
  description String?
  enabled     Boolean   @default(true)
  date_taken  DateTime?
  created_at  DateTime  @default(now())

  user_id Int?
  user    User? @relation(fields: [user_id], references: [id])

  edition_id String?
  edition    Edition? @relation(fields: [edition_id], references: [id])

  categories Category[] // Implicit many-to-many relation
}

model User {
  id           Int     @id @default(autoincrement())
  ign          String?
  discord_name String
  discord_id   String  @unique
  password     String?
  enabled      Boolean @default(false)
  joined_at    DateTime @default(now())

  photos Photo[]
  roles  Role[]
  emblems Emblem[]
}

model Edition {
  id      String   @id
  name    String
  icon    String?
  photos  Photo[]
  emblems Emblem[]
}

model Category {
  id     String  @id
  name   String
  icon   String?
  color  String?
  photos Photo[]
}

model Role {
  id       String @id
  name     String
  color    String
  position Int    @default(0)
  users    User[]
}

model Emblem {
  id          String   @id
  name        String
  description String
  icon_url    String
  edition_id  String?
  edition     Edition? @relation(fields: [edition_id], references: [id])
  users       User[]
}
